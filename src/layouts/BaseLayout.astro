---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
}
const {
  title = 'glepzilla — дом Глеба в интернете',
  description = 'Тексты, проекты и всё остальное, что не помещается в соцсети.',
  image = '/logo.png',
  article = false
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const imageUrl = new URL(image, Astro.site);
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#141f0e" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="Блог glepzilla" href="/rss.xml" />
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content="glepzilla" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#content">К содержанию</a>
    <SiteHeader />
    <main id="content"><slot /></main>
    <SiteFooter />
  </body>
</html>
