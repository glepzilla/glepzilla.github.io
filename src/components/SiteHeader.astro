---
const path = Astro.url.pathname;
const links = [
  { href: '/blog/', label: 'Блог' },
  { href: '/projects/', label: 'Проекты' },
  { href: '/about/', label: 'Обо мне' }
];
const mossStrands = [
  { x: '5%', height: '8px', delay: '-1.1s', rotate: '-24deg' },
  { x: '18%', height: '14px', delay: '-2.4s', rotate: '28deg' },
  { x: '34%', height: '7px', delay: '-0.6s', rotate: '-18deg' },
  { x: '49%', height: '17px', delay: '-3.2s', rotate: '26deg' },
  { x: '66%', height: '10px', delay: '-1.8s', rotate: '-22deg' },
  { x: '81%', height: '15px', delay: '-2.8s', rotate: '24deg' },
  { x: '95%', height: '8px', delay: '-0.9s', rotate: '-25deg' }
];
---

<header class="site-header container" data-site-header>
  <a class="brand" href="/" aria-label="glepzilla — на главную">
    <img src="/logo.png" width="48" height="48" alt="" />
    <span class="wordmark">
      glepzilla
      <span class="moss-line" aria-hidden="true">
        {mossStrands.map((strand) => (
          <i style={`--strand-x:${strand.x};--strand-height:${strand.height};--strand-delay:${strand.delay};--leaf-rotate:${strand.rotate}`}></i>
        ))}
      </span>
    </span>
  </a>

  <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-navigation" aria-label="Открыть меню">
    <span></span><span></span><span></span>
  </button>

  <nav id="site-navigation" aria-label="Основная навигация">
    {links.map((link) => (
      <a class:list={["nav-link", { active: path.startsWith(link.href) }]} href={link.href} aria-current={path.startsWith(link.href) ? 'page' : undefined}>
        {link.label}
      </a>
    ))}
    <span class="language" title="Английская версия появится позже">RU/<span>EN</span></span>
  </nav>
</header>

<script>
  const siteHeaders = document.querySelectorAll<HTMLElement>('[data-site-header]');

  siteHeaders.forEach((header) => {
    const toggle = header.querySelector<HTMLButtonElement>('.menu-toggle');
    const navigation = header.querySelector<HTMLElement>('nav');
    if (!toggle || !navigation) return;

    const setMenuOpen = (open: boolean) => {
      header.toggleAttribute('data-menu-open', open);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Закрыть меню' : 'Открыть меню');
    };

    toggle.addEventListener('click', () => setMenuOpen(!header.hasAttribute('data-menu-open')));
    navigation.addEventListener('click', (event) => {
      if ((event.target as HTMLElement).closest('a')) setMenuOpen(false);
    });
    document.addEventListener('click', (event) => {
      if (!header.contains(event.target as Node)) setMenuOpen(false);
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        setMenuOpen(false);
        toggle.focus();
      }
    });
    window.matchMedia('(min-width: 681px)').addEventListener('change', (event) => {
      if (event.matches) setMenuOpen(false);
    });
  });
</script>

<style>
  .site-header { min-height: 92px; display: flex; align-items: center; justify-content: space-between; gap: 32px; position: relative; z-index: 40; }
  .brand { display: inline-flex; align-items: center; gap: 13px; color: var(--gz-text-on-dark); font-family: var(--gz-font-display); font-size: 1.45rem; font-weight: 600; line-height: 1; text-decoration: none; }
  .brand img { display: block; width: 48px; height: 48px; border-radius: 50%; transition: rotate var(--gz-motion-base) var(--gz-ease-out), scale var(--gz-motion-base) var(--gz-ease-out), box-shadow var(--gz-motion-base) ease; }
  .brand:hover img { rotate: -4deg; scale: 1.06; box-shadow: 0 0 0 3px rgba(143, 175, 106, 0.22); }
  .wordmark { position: relative; display: inline-block; padding: 0 1px 11px; margin-bottom: -11px; transition: color var(--gz-motion-fast) ease; }
  .brand:hover .wordmark { color: var(--gz-sage-200); }
  .moss-line { position: absolute; left: 0; right: 0; bottom: 5px; height: 3px; border-radius: 999px; background: var(--gz-moss-700); opacity: 0.95; }
  .moss-line::before, .moss-line::after { content: ''; position: absolute; bottom: -2px; width: 8px; height: 6px; border-radius: 60% 40% 55% 45%; background: var(--gz-moss-400); }
  .moss-line::before { left: 25%; rotate: -18deg; }
  .moss-line::after { right: 13%; rotate: 20deg; }
  .moss-line i { position: absolute; left: var(--strand-x); top: 1px; width: 3px; height: var(--strand-height); border-radius: 0 0 999px 999px; background: var(--gz-moss-400); transform-origin: 50% 0; animation: moss-sway 4.2s ease-in-out var(--strand-delay) infinite; }
  .moss-line i::after { content: ''; position: absolute; left: 1px; bottom: -2px; width: 7px; height: 4px; border-radius: 70% 20% 70% 20%; background: var(--gz-moss-400); rotate: var(--leaf-rotate); transform-origin: 0 50%; }
  nav { display: flex; align-items: center; gap: clamp(16px, 3vw, 30px); }
  .nav-link { position: relative; color: var(--gz-sage-200); font-size: 0.9rem; font-weight: 600; text-decoration: none; transition: color var(--gz-motion-fast) ease, translate var(--gz-motion-fast) var(--gz-ease-out); }
  .nav-link::after { content: ''; position: absolute; left: 0; right: 0; bottom: -8px; height: 1px; background: var(--gz-moss-400); scale: 0 1; transform-origin: 0 50%; transition: scale var(--gz-motion-base) var(--gz-ease-out); }
  .nav-link:hover, .nav-link.active { color: var(--gz-moss-400); }
  .nav-link:hover { translate: 0 -2px; }
  .nav-link:hover::after, .nav-link.active::after { scale: 1 1; }
  .language { color: var(--gz-sage-300); font-family: var(--gz-font-mono); font-size: 0.75rem; }
  .language span { opacity: 0.4; }
  .menu-toggle { display: none; }

  @keyframes moss-sway {
    0%, 100% { rotate: -3deg; }
    50% { rotate: 5deg; }
  }

  @media (max-width: 680px) {
    .site-header { min-height: 82px; gap: 14px; }
    .brand { gap: 10px; font-size: 1.18rem; }
    .brand img { width: 43px; height: 43px; }
    .wordmark { padding-bottom: 10px; margin-bottom: -10px; }
    .moss-line i { scale: 0.85; }
    .menu-toggle { display: inline-flex; flex-direction: column; align-items: center; justify-content: center; gap: 5px; width: 44px; height: 44px; padding: 0; border: 1px solid var(--gz-border-tile); border-radius: 12px; background: var(--gz-forest-800); color: var(--gz-paper-100); cursor: pointer; transition: border-color var(--gz-motion-fast) ease, background var(--gz-motion-fast) ease, scale var(--gz-motion-fast) ease; }
    .menu-toggle:hover { border-color: var(--gz-moss-400); background: var(--gz-forest-700); }
    .menu-toggle:active { scale: 0.95; }
    .menu-toggle span { width: 19px; height: 2px; border-radius: 999px; background: currentColor; transition: rotate var(--gz-motion-base) var(--gz-ease-out), translate var(--gz-motion-base) var(--gz-ease-out), opacity var(--gz-motion-fast) ease; }
    [data-menu-open] .menu-toggle span:nth-child(1) { translate: 0 7px; rotate: 45deg; }
    [data-menu-open] .menu-toggle span:nth-child(2) { opacity: 0; }
    [data-menu-open] .menu-toggle span:nth-child(3) { translate: 0 -7px; rotate: -45deg; }
    nav { position: absolute; top: calc(100% - 1px); left: 0; right: 0; display: flex; flex-direction: column; align-items: stretch; gap: 0; padding: 12px; border: 1px solid var(--gz-border-tile); border-radius: var(--gz-radius-tile); background: var(--gz-forest-800); box-shadow: var(--gz-shadow-tile); opacity: 0; visibility: hidden; pointer-events: none; translate: 0 -10px; scale: 0.98; transform-origin: 50% 0; transition: opacity var(--gz-motion-fast) ease, visibility var(--gz-motion-fast) ease, translate var(--gz-motion-base) var(--gz-ease-out), scale var(--gz-motion-base) var(--gz-ease-out); }
    [data-menu-open] nav { opacity: 1; visibility: visible; pointer-events: auto; translate: 0 0; scale: 1; }
    .nav-link { padding: 12px 14px; border-radius: 10px; font-size: 0.95rem; }
    .nav-link:hover, .nav-link.active { background: rgba(143, 175, 106, 0.1); translate: 0; }
    .nav-link::after { display: none; }
    .language { padding: 10px 14px 7px; border-top: 1px solid var(--gz-border-tile); margin-top: 6px; }
  }
</style>
