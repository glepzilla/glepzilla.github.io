---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostRow from '../components/PostRow.astro';
import SocialLinks from '../components/SocialLinks.astro';
import Tag from '../components/Tag.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf());
---
<BaseLayout>
  <section class="hero container" data-reveal>
    <div class="ligature" aria-hidden="true">gz</div>
    <div class="hero-copy">
      <p class="eyebrow eyebrow--moss">Личный сайт · с 2026</p>
      <h1 class="display-title">Мой дом<br />в интернете<span class="title-dot">.</span></h1>
      <p class="intro">Я Глеб. Здесь растут тексты, проекты и всё остальное, что не помещается в соцсети.</p>
    </div>
    <span class="sticker">обновлено 14.07</span>
  </section>

  <section class="desk container" aria-label="Последние материалы и контакты">
    <div class="paper-card latest" data-reveal="left">
      <div class="card-head">
        <span class="eyebrow eyebrow--paper">Блог / свежее</span>
        <a class="text-link text-link--paper" href="/blog/">всё →</a>
      </div>
      {posts.slice(0, 3).map((post) => (
        <PostRow href={`/blog/${post.id}/`} title={post.data.title} date={post.data.published} />
      ))}
    </div>

    <div class="side-stack" data-reveal="right" style="--reveal-delay: 120ms">
      <a class="about-card" href="/about/">
        <img src="/logo.png" width="82" height="82" alt="" />
        <span>
          <strong>Кто я и чем занимаюсь →</strong>
          <small class="eyebrow">Обо мне</small>
        </span>
      </a>
      <div class="dark-tile contacts">
        <span class="eyebrow eyebrow--faint">Где меня найти</span>
        <SocialLinks compact />
      </div>
    </div>
  </section>

  <section class="projects container" data-reveal>
    <div class="section-line">
      <span class="eyebrow eyebrow--moss">Проекты, которыми горжусь</span>
      <a class="text-link" href="/projects/">все проекты →</a>
    </div>
    <div class="project-grid">
      <a class="dark-tile project-card project-card--one" href="https://github.com/glepzilla/shiki-cards-bot" rel="noreferrer" data-reveal style="--reveal-delay: 40ms">
        <span class="number">01</span>
        <div><h2>Shiki Cards Bot →</h2><p>Telegram-бот и небольшой живой проект из организации glepzilla.</p></div>
        <div class="tags"><Tag>telegram</Tag><Tag>open source</Tag></div>
      </a>
      <a class="dark-tile project-card project-card--two" href="https://github.com/glepzilla/glepzilla.github.io" rel="noreferrer" data-reveal style="--reveal-delay: 120ms">
        <span class="number">02</span>
        <div><h2>Этот сайт →</h2><p>Тихий уголок для заметок, проектов и экспериментов.</p></div>
        <div class="tags"><Tag>astro</Tag><Tag>markdown</Tag></div>
      </a>
      <a class="dark-tile project-card project-card--three" href="/blog/" data-reveal style="--reveal-delay: 200ms">
        <span class="number">03</span>
        <div><h2>Записки на полях →</h2><p>Мысли о работе, инструментах и медленных проектах.</p></div>
        <div class="tags"><Tag>тексты</Tag></div>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { min-height: 410px; position: relative; display: flex; align-items: center; padding-top: 48px; padding-bottom: 42px; overflow: hidden; }
  .hero-copy { position: relative; z-index: 2; }
  .hero .eyebrow { margin: 0 0 18px; }
  .intro { max-width: 520px; margin: 24px 0 0; color: var(--gz-sage-300); font-size: 1.08rem; line-height: 1.65; }
  .ligature { position: absolute; z-index: 0; right: -32px; top: -82px; color: rgba(143, 175, 106, 0.1); font-family: var(--gz-font-display); font-size: clamp(14rem, 29vw, 22rem); font-weight: 600; line-height: 1; pointer-events: none; user-select: none; animation: ligature-drift 9s ease-in-out infinite; }
  .sticker { position: absolute; z-index: 3; top: 74px; right: 170px; display: inline-block; padding: 8px 14px; transform: rotate(6deg); border-radius: var(--gz-radius-sm); background: var(--gz-amber-400); box-shadow: var(--gz-shadow-sticker); color: var(--gz-moss-900); font-family: var(--gz-font-mono); font-size: 0.74rem; font-weight: 700; letter-spacing: 0.06em; animation: sticker-float 4.8s ease-in-out infinite; }
  .desk { position: relative; display: grid; grid-template-columns: minmax(0, 1.22fr) minmax(330px, 0.88fr); align-items: start; }
  .latest { position: relative; z-index: 2; padding: 32px 36px; transform: rotate(-1.2deg); }
  .card-head, .section-line { display: flex; justify-content: space-between; align-items: center; gap: 20px; }
  .card-head { margin-bottom: 8px; }
  .card-head .text-link, .section-line .text-link { font-size: 0.82rem; }
  .side-stack { position: relative; z-index: 3; display: flex; flex-direction: column; gap: 20px; margin: 36px 0 0 -28px; }
  .about-card { display: flex; align-items: center; gap: 20px; padding: 27px 30px; transform: rotate(1.6deg); border-radius: 20px; background: var(--gz-moss-600); box-shadow: var(--gz-shadow-tile); color: var(--gz-paper-50); text-decoration: none; transition: background var(--gz-motion-fast) ease, translate var(--gz-motion-base) var(--gz-ease-out), scale var(--gz-motion-base) var(--gz-ease-out), box-shadow var(--gz-motion-base) ease; }
  .about-card:hover { background: var(--gz-moss-700); translate: 0 -5px; scale: 1.01; box-shadow: 0 30px 68px -20px rgba(0,0,0,0.65); }
  .about-card img { flex: none; width: 82px; height: 82px; border-radius: 50%; box-shadow: 0 0 0 3px rgba(242, 236, 217, 0.35); }
  .about-card span { display: flex; flex-direction: column; align-items: flex-start; }
  .about-card strong { font-family: var(--gz-font-display); font-size: 1.3rem; font-weight: 500; line-height: 1.35; }
  .about-card small { margin-top: 6px; color: var(--gz-sage-200); opacity: 0.8; }
  .contacts { padding: 23px 28px; transform: rotate(-0.8deg); }
  .contacts :global(.social-links) { margin-top: 11px; }
  .projects { padding-top: 86px; }
  .section-line { margin-bottom: 22px; }
  .project-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .project-card { min-height: 270px; display: flex; flex-direction: column; justify-content: space-between; padding: 27px 29px; text-decoration: none; }
  .project-card--one { transform: rotate(0.6deg); }
  .project-card--two { transform: rotate(-0.9deg) translateY(8px); }
  .project-card--three { transform: rotate(1.1deg); }
  .project-card:hover { transform: rotate(0) translateY(-3px); }
  .number { color: var(--gz-text-faint); font-family: var(--gz-font-mono); font-size: 0.7rem; letter-spacing: 0.1em; }
  .project-card h2 { margin: 0 0 8px; font-family: var(--gz-font-display); font-size: 1.38rem; font-weight: 500; line-height: 1.3; }
  .project-card p { margin: 0; color: var(--gz-sage-300); font-size: 0.82rem; line-height: 1.55; }
  .tags { display: flex; flex-wrap: wrap; gap: 7px; }
  @keyframes sticker-float { 0%, 100% { translate: 0 0; } 50% { translate: 0 -6px; } }
  @keyframes ligature-drift { 0%, 100% { translate: 0 0; rotate: 0deg; } 50% { translate: -8px 5px; rotate: -1deg; } }
  @media (max-width: 900px) {
    .sticker { right: 90px; }
    .desk { grid-template-columns: 1fr; }
    .side-stack { display: grid; grid-template-columns: 1fr 0.8fr; margin: -2px 18px 0; }
    .project-grid { grid-template-columns: 1fr 1fr; }
    .project-card:last-child { grid-column: 1 / -1; min-height: 220px; }
  }
  @media (max-width: 680px) {
    .hero { min-height: 380px; padding-top: 35px; }
    .sticker { top: auto; right: 16px; bottom: 40px; }
    .ligature { right: -70px; top: -10px; }
    .latest { padding: 26px 22px; }
    .side-stack { display: flex; margin: -4px 8px 0; }
    .about-card { padding: 22px; }
    .about-card img { width: 68px; height: 68px; }
    .projects { padding-top: 66px; }
    .project-grid { grid-template-columns: 1fr; }
    .project-card, .project-card:last-child { grid-column: auto; min-height: 230px; }
    .section-line .text-link { display: none; }
  }
</style>
