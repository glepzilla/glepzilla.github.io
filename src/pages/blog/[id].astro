---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const published = new Intl.DateTimeFormat('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' }).format(post.data.published);
---
<BaseLayout title={`${post.data.title} — glepzilla`} description={post.data.description} article>
  <article class="post container" data-reveal>
    <a class="back text-link" href="/blog/">← ко всем постам</a>
    <div class="paper-card sheet">
      <div class="meta">
        <time datetime={post.data.published.toISOString()}>{published}</time>
        <span>·</span>
        <span>{post.data.tags.join(' · ')}</span>
      </div>
      <h1>{post.data.title}</h1>
      <p class="lead">{post.data.description}</p>
      <div class="prose"><Content /></div>
      <footer class="post-footer">
        <img src="/logo.png" width="52" height="52" alt="" />
        <strong>Глеб</strong>
        <a class="text-link text-link--paper" href="https://github.com/gl-epka" rel="me noreferrer">написать в GitHub →</a>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .post { max-width: 900px; padding-top: 58px; }
  .back { display: inline-block; margin: 0 0 22px; font-family: var(--gz-font-mono); font-size: 0.75rem; }
  .sheet { position: relative; overflow: hidden; padding: clamp(30px, 7vw, 64px); transform: rotate(-0.35deg); background-image: radial-gradient(circle at 12% 5%, rgba(173, 145, 84, 0.08), transparent 25%), radial-gradient(circle at 88% 82%, rgba(90, 122, 60, 0.055), transparent 28%), repeating-linear-gradient(8deg, rgba(54, 67, 43, 0.018) 0 1px, transparent 1px 8px); }
  .sheet::before { content: ''; position: absolute; inset: 13px; border: 1px solid rgba(90, 106, 77, 0.12); border-radius: calc(var(--gz-radius-card) - 8px); pointer-events: none; }
  .meta { display: flex; flex-wrap: wrap; gap: 9px; color: var(--gz-moss-600); font-family: var(--gz-font-mono); font-size: 0.72rem; letter-spacing: 0.06em; text-transform: uppercase; }
  h1 { max-width: 720px; margin: 17px 0 18px; color: var(--gz-ink-900); font-family: var(--gz-font-display); font-size: clamp(2.2rem, 6vw, 3.5rem); font-weight: 500; line-height: 1.12; letter-spacing: -0.03em; }
  .lead { margin: 0 0 40px; color: var(--gz-ink-500); font-size: 1.05rem; line-height: 1.65; }
  .post-footer { display: flex; align-items: center; gap: 15px; margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--gz-paper-300); color: var(--gz-ink-500); }
  .post-footer img { flex: none; width: 52px; height: 52px; border-radius: 50%; }
  .post-footer strong { color: var(--gz-ink-900); font-size: 0.75rem; }
  .post-footer a { margin-left: auto; font-size: 0.78rem; }
  @media (max-width: 600px) { .post { padding-top: 40px; } .post-footer { align-items: flex-start; flex-wrap: wrap; } .post-footer a { width: 100%; margin: 4px 0 0; } }
</style>
